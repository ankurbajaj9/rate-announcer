# ── ENTSO-E API ───────────────────────────────────────────────────────────────
# Get your token at https://transparency.entsoe.eu/ → My Account → Web API Security Token
ENTSOE_API_TOKEN=YOUR_ENTSOE_TOKEN_HERE

# Bidding zone / price area. Common values: SE_1 SE_2 SE_3 SE_4 FI NO_1 DK_1
PRICE_AREA=SE_3

# ── Google Home ───────────────────────────────────────────────────────────────
# Exact friendly name shown in the Google Home app (case-sensitive)
GOOGLE_HOME_NAME=Kitchen speaker

# BCP-47 language code for gTTS text-to-speech. Examples: en  sv  de  fi
TTS_LANGUAGE=sv

# ── Alert Threshold ───────────────────────────────────────────────────────────
# Fraction of the day's maximum price above which an alert is triggered.
# 0.75 = alert when price is ≥ 75 % of today's peak.
THRESHOLD_PERCENT=0.75

# ── Quiet Hours (no announcements will be made during this window) ─────────────
# 24-hour clock. Default: 22 – 07 (10 PM to 7 AM).
QUIET_HOURS_START=22
QUIET_HOURS_END=7

# ── Notification Settings ─────────────────────────────────────────────────────
# Minimum seconds between repeat notifications (reserved for future use).
NOTIFICATION_COOLDOWN_SEC=3600

# Announcement window in minutes around a scheduled alert (reserved for future use).
ANNOUNCE_MINUTE_WINDOW=5

# Seconds to wait before playing the daily summary after startup.
SUMMARY_ANNOUNCE_DELAY_SEC=2

# ── HTTP Server (used to serve the TTS audio to the Chromecast) ───────────────
# Must be reachable by the Google Home device on your local network.
SERVE_PORT=8765

# ── Cache / State Files ───────────────────────────────────────────────────────
PRICE_CACHE_FILE=/tmp/rate_announcer_prices.pkl
FX_CACHE_FILE=/tmp/rate_announcer_fx.json
STATE_FILE=/tmp/price_monitor_state
